# ─── watsonx.ai (필수) ──────────────────────────────────────────────────────
# IBM Cloud 에서 받은 watsonx.ai 자격증명.
# https://cloud.ibm.com/iam/apikeys 에서 API key 발급.

WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_APIKEY=your-ibm-cloud-api-key-here


# ─── watsonx Project (PDF/PPTX VLM 캡션용) ───────────────────────────────────
# watsonx.ai 콘솔 → Projects → 본인 project → Manage 탭에서 ID 확인.
# PDF / PPTX 의 이미지 캡셔닝(VLM) 단계에서 사용.

WATSONX_PROJECT_ID=00000000-0000-0000-0000-000000000000


# ─── watsonx Space (Text Extraction V2 용) ──────────────────────────────────
# DOCX, XLSX, PPTX(텍스트 추출) 에서 사용하는 watsonx Deployment Space.
# Space 가 없으면 watsonx.ai 콘솔 → Deployments → New deployment space 로 생성.
# Space 에 COS 인스턴스를 연결해야 하며, 그 버킷 이름을 COS_BUCKET_NAME 으로.

SPACE_ID=00000000-0000-0000-0000-000000000000
COS_BUCKET_NAME=your-watsonx-space-bucket


# ─── (선택) Master COS — 추출된 이미지를 별도 버킷으로 업로드할 때 ─────────────
# 이 항목은 후속 RAG / agent 가 이미지의 pre-signed URL 을 받아야 할 때만 필요.
# 단순히 로컬에 파일만 떨어뜨리면 되는 경우 비워둬도 됨.
# IBM Cloud Object Storage 인스턴스 → Service credentials → "Include HMAC credential"
# 옵션으로 새 credential 발급한 뒤 access_key_id / secret_access_key 입력.

# MASTER_COS_ENDPOINT=https://s3.<region>.cloud-object-storage.appdomain.cloud
# MASTER_COS_ACCESS_KEY=
# MASTER_COS_SECRET_KEY=
